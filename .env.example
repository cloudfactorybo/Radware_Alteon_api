# Postgres
POSTGRES_USER=alteon
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=alteon

# Redis (opcional — deja vacío para sin password)
REDIS_PASSWORD=changeme-redis-password

# App
LOG_LEVEL=info
LOG_FORMAT=text
ALLOWED_ORIGINS=*
# AUTH_DISABLED=true   # descomenta para apagar Bearer token en dev

# Traefik (puerto público HTTPS)
PUBLIC_HTTPS_PORT=5687
